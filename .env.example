# ASI:One
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1/chat/completions
ASI_ONE_MODEL=asi1-mini
AGRIBROKER_INTENT_MODE=local
AGRIBROKER_DISCOVERY_MODE=local
AGRIBROKER_REGISTRY_ADDRESS=

# Payments
# Buyer funding: simulated | stripe (Stripe Checkout)
AGRIBROKER_BUYER_PAYMENT_MODE=stripe
# Farm payout: simulated | testnet (FET) | stripe_connect (Stripe Connect transfers)
AGRIBROKER_FARM_PAYMENT_MODE=simulated
STRIPE_SECRET_KEY=
STRIPE_SUCCESS_URL=https://example.com/agribroker/success
STRIPE_CANCEL_URL=https://example.com/agribroker/cancel
# Stripe Connect farm payouts are OFF by default. Only set to "true" once each
# farm has a real onboarded Stripe connected account (acct_...). Leave false for demos.
STRIPE_CONNECT_TRANSFERS_ENABLED=false
# Stripe Connect onboarding is separate from transfers. Leave false for simulated onboarding.
STRIPE_CONNECT_ONBOARDING_ENABLED=false
FETCH_DENOM=atestfet
FETCH_NETWORK=testnet
FETCH_EXPLORER_TX_URL=https://explore-fetchhub.fetch.ai/transactions

# Agent seeds - replace before deployment and never commit real secrets.
REGISTRY_SEED=agribroker-registry-demo-seed-change-before-deploy
ORCHESTRATOR_SEED=agribroker-orchestrator-demo-seed-change-before-deploy
STRUCTURED_ORCHESTRATOR_SEED=agribroker-orchestrator-demo-seed-change-before-deploy
STRUCTURED_ORCHESTRATOR_PORT=8201
FARM_A_SEED=agri-farm-a-demo-seed-change-before-deploy
FARM_B_SEED=agri-farm-b-demo-seed-change-before-deploy
FARM_C_SEED=agri-farm-c-demo-seed-change-before-deploy
SUNNY_ACRES_SEED=agri-sunny-acres-demo-seed-change-before-deploy
